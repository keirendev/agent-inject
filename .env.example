# NovaCrest AI Security Lab — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Your public IP address for security group allowlisting
# Run: curl -s https://checkip.amazonaws.com
OPERATOR_IP=0.0.0.0

# Bedrock model IDs (defaults should work, change if using different models)
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Optional: for final validation runs
# BEDROCK_VALIDATION_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
